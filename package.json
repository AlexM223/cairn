{
	"name": "heartwood",
	"description": "Heartwood — self-hosted Bitcoin command center: block explorer, watch-only wallet navigator, and multi-user instance you run yourself. Your bitcoin. Your rules.",
	"private": true,
	"version": "0.2.34",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/AlexM223/cairn"
	},
	"keywords": [
		"bitcoin",
		"block-explorer",
		"electrum",
		"self-hosted",
		"watch-only",
		"xpub",
		"sveltekit"
	],
	"engines": {
		"node": ">=22.5"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node server.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"test": "vitest run",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"mining:forced-solve-harness": "node scripts/mining/forcedSolveHarness.mjs",
	"mining:forced-solve": "node scripts/qa/mining-forced-solve.mjs",
	"mining:load-test": "node scripts/qa/mining-load-test.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/nodemailer": "^8.0.1",
		"@types/qrcode": "^1.5.6",
		"esbuild": "^0.28.1",
		"playwright-core": "^1.61.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-top-level-await": "^1.6.0",
		"vite-plugin-wasm": "^3.6.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource/inter": "^5.2.8",
		"@ledgerhq/hw-app-btc": "^11.2.1",
		"@ledgerhq/hw-transport-webhid": "^6.36.0",
		"@noble/hashes": "^2.2.0",
		"@scure/base": "^2.2.0",
		"@scure/bip32": "^2.2.0",
		"@scure/bip39": "^1.6.0",
		"@scure/btc-signer": "^2.2.0",
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.2",
		"@trezor/connect-web": "^9.7.3",
		"bbqr": "^1.2.0",
		"bitbox-api": "^0.13.0",
		"buffer": "^6.0.3",
		"jadets": "1.1.18",
		"jspdf": "^4.2.1",
		"nodemailer": "^9.0.3",
		"nostr-tools": "^2.23.9",
		"openpgp": "^6.3.1",
		"pino": "^9.14.0",
		"pino-pretty": "^13.1.3",
		"qrcode": "^1.5.4",
		"selfsigned": "^5.5.0",
		"socks": "^2.8.9",
		"socks-proxy-agent": "^8.0.5"
	}
}
